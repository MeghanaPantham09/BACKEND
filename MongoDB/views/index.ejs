<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini Whatsapp</title>
    <link href="style.css" rel="stylesheet">
</head>
<body>
    <form method="GET" action="/chats/new">
                <button>Add New Chat</button>
             </form>
             <br> <br>          
    <h3>All Chats!</h3>
    <% for(let chat of chats){ %>
        <div class="chat">
            <p>From : <i> <%= chat.from %> </i></p>
            <div class="msg"> 
                <p>msg: <%= chat.msg %></p>
                <form method="GET" action="/chats/<%= chat.id %>/edit">
                <button>Edit Chat</button>
             </form>
            </div>
           
             <p>Recieved by: <i><%= chat.to %></i></p>
             
             <hr/>
             <p><%= chat.created_at.toString().split(" ")[4]%></p>
             <p><%= chat.created_at.toString().split(" ").splice(0,4).join("-")%></p>
             
             <form method="POST" action="/chats/<%=chat.id%>?_method=DELETE">
                <button>Delete Chat</button>
             </form>
        </div>
        <br>
        <br><br>

    <%} %>


</body>
</html>